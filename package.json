{
  "name": "nrc-seat-optimiser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Enumerate every valid split-ticket combination (with total price) for a single-train NRC Lagos–Ibadan journey.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ext": "node scripts/build-extension.mjs",
    "dry-run": "tsx src/server/dryRun.ts",
    "bot": "tsx src/server/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "twitter-api-v2": "^1.18.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
